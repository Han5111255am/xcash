# Xcash local development environment template.
# Copy to `.env` for local development only:
#   cp .env.example .env
#
# Production should use `make init-env` to generate random secrets.
# Never commit `.env`.

# Domain and listener
SITE_DOMAIN=localhost
LISTEN_TO=127.0.0.1

# Django
DJANGO_DEBUG=True
DJANGO_SECRET_KEY=django-insecure-dev-example-only-change-me
DJANGO_DEFAULT_SUPERUSER_PASSWORD=Admin@123456
# Optional custom admin path. Leave empty to use the default route.
ADMIN_PATH=

# Performance profile: low, medium, high
PERFORMANCE=low

# PostgreSQL
POSTGRES_DB=xcash
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1

# Wallet mnemonic encryption key.
# For production, this value must be high entropy and must never change after first use.
WALLET_MNEMONIC_ENCRYPTION_KEY=dev-wallet-mnemonic-encryption-key-change-me

# Reverse proxy / SaaS integration
TRUSTED_PROXY_IPS=127.0.0.1,::1
SAAS_API_TOKEN=
IS_SAAS=False
SAAS_CALLBACK_URL=http://xcash-saas-caddy

# Webhook / local integration
WEBHOOK_ALLOW_INTERNAL_TARGETS=True

# Local development services
FLOWER_PORT=5555
LOCAL_EVM_PORT=8545
LOCAL_EVM_CHAIN_ID=31337
LOCAL_EVM_BLOCK_TIME=12
LOCAL_EVM_STATE_INTERVAL=5

# Optional local ERC20 mock addresses. Leave empty to auto-deploy during local chain bootstrap.
LOCAL_EVM_USDT_ADDRESS=
LOCAL_EVM_USDC_ADDRESS=
LOCAL_EVM_DAI_ADDRESS=

# Optional worker tuning overrides
GUNICORN_WORKERS=
GUNICORN_THREADS=
CELERY_WORKER_CONCURRENCY=
CELERY_BUSINESS_WORKER_CONCURRENCY=
CELERY_STRESS_WORKER_CONCURRENCY=
CELERY_SCAN_WORKER_CONCURRENCY=
